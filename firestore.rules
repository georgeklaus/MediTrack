rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: any authenticated user can read/write (existing collections)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Conversations: only participants can read or write
    match /conversations/{convId} {
      allow read, write: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Allow conversation creation by the initiating user
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      // Messages: only participants of the parent conversation can access
      match /messages/{msgId} {
        allow read: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        allow create: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}

